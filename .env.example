# 复制本文件为 .env，填入你自己的 key

# === Claude API ===
# 从 https://console.anthropic.com/ 拿
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# === OpenAI（DALL-E 3，V0.2 接入图像时启用）===
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
DALLE_MODEL=dall-e-3

# === WebSearch（可选）===
# 当前用 Claude WebSearch tool，无需额外 key
# 后续可改 SerpAPI / Tavily

# === 存储 ===
# V0.1 用本地文件 + SQLite
DATA_DIR=./data
SESSIONS_DIR=./sessions
DB_PATH=./data/tpagent.db

# === Cloudflare R2（V0.2 启用）===
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=tpagent-images
R2_PUBLIC_URL=

# === 服务 ===
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# === 配置文件路径（如要自定义风格）===
CONFIG_DIR=../config
